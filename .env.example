# DigitalOcean API token with Gradient AI (GenAI) scope. Required for all provisioning/verify scripts.
DO_API_TOKEN=

# Person B's live /screen endpoint. Until it exists, leave blank and run `npm run mock` (defaults to http://localhost:8787/screen).
SCREEN_URL=

# Optional: pin the DigitalOcean region for agents + KB (keep agents and KB co-located).
DO_REGION=tor1

# Optional: DigitalOcean project id to group the created resources.
DO_PROJECT_ID=

# Per-agent endpoint access keys (created during provisioning; see README-personA.md).
AGENT_KEY_INTAKE=
AGENT_KEY_FOOD_CALFRESH=
AGENT_KEY_ROUTER=
