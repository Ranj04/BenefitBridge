# DigitalOcean API token with Gradient AI (GenAI) scope. Required for all provisioning/verify scripts.
DO_API_TOKEN=

# Person B's live /screen endpoint. Until it exists, leave blank and run `npm run mock` (defaults to http://localhost:8787/screen).
SCREEN_URL=

# Optional: pin the DigitalOcean region for agents + KB (keep agents and KB co-located).
DO_REGION=tor1

# Required for provisioning. Copy the BenefitBridge project id from its DigitalOcean project URL.
# Provisioning fails closed when this is blank; it never selects a default project.
DO_PROJECT_ID=

# Server-side agent endpoints and access keys. Local development can read the
# gitignored .gradient-state.json created by provisioning; production uses these.
AGENT_INTAKE_URL=
AGENT_INTAKE_KEY=
AGENT_FOOD_URL=
AGENT_FOOD_KEY=
